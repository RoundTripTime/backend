# local 프로파일 오버레이 템플릿.
# 사본을 application-local.yml 로 만들어 사용한다 (실파일은 .gitignore 처리됨).
# local 프로파일에서는 LocalSocialIdTokenVerifierConfig 의 페이크 검증기가 활성화되어
# 카카오/구글 실제 OIDC 토큰 없이 /auth/social 호출이 가능하다.
# Swagger UI 의 Authorize 에 발급받은 access_token 을 넣으면 DELETE /auth/session 도 호출 가능.

jwt:
  secret: ${JWT_SECRET:local-development-only-secret-key-min-32-bytes-aaaaaa}

logging:
  level:
    roundtrip: DEBUG
    # 인증/필터체인 디버깅이 필요할 때만 임시로 활성화.
    # org.springframework.security: DEBUG
