# Copy this file to `.env` and fill real values for local dev.
# `.env` is gitignored.

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=local

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roundtrip
DB_USERNAME=roundtrip
DB_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# Generate a 256-bit (32+ byte) random secret, e.g.:
#   openssl rand -base64 48
# or in PowerShell:
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 }))
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-bytes
JWT_ACCESS_EXPIRY_MS=1800000
JWT_REFRESH_EXPIRY_MS=1209600000
